[NASNE]
# nasneのIP。通常は空のままでOK（初回起動時に自動発見してここに書き込まれます）
# IPが変わった時は komenasne.exe --discover で再探索して更新できます
# 手動で設定する場合はカンマ区切りで記入してください
ip =

[PLAYER]
# komeview のパスを設定 (https://github.com/nyumen/komeview)
# macの場合の例: /Applications/komeview.app/Contents/MacOS/komeview
komeview_path = C:\Users\yourname\AppData\Local\Programs\komeview\komeview.exe
# jkcommentviewer.exe のパスを設定（ライブ視聴連動を使う場合のみ・省略可）
jkcommentviewer_path =

[LOG]
# 取得したコメントの保存フォルダ
kakolog_dir = .\kakolog\

[BLUESKY]
# 視聴記録をBlueskyに投稿する場合のみ設定（省略可）
# app_password は Bluesky の 設定 > アプリパスワード で発行できます
handle =
app_password =
